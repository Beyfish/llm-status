{
  "name": "llm-status",
  "version": "0.1.0",
  "description": "LLM API Status Manager - Monitor and manage all your LLM API providers in one place",
  "main": "dist-electron/main.js",
  "author": "LLM Status Team",
  "license": "MIT",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "tsc && electron-vite build && electron-builder --publish never",
    "build:win": "tsc && electron-vite build && electron-builder --win --publish never",
    "build:mac": "tsc && electron-vite build && electron-builder --mac --publish never",
    "build:linux": "tsc && electron-vite build && electron-builder --linux --publish never",
    "publish": "tsc && electron-vite build && electron-builder --publish always",
    "publish:win": "tsc && electron-vite build && electron-builder --win --publish always",
    "publish:mac": "tsc && electron-vite build && electron-builder --mac --publish always",
    "publish:linux": "tsc && electron-vite build && electron-builder --linux --publish always",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "test": "vitest",
    "test:coverage": "vitest --coverage",
    "test:e2e": "playwright test"
  },
  "dependencies": {
    "@aws-sdk/client-bedrock-runtime": "^3.700.0",
    "@aws-sdk/client-s3": "^3.700.0",
    "@aws-sdk/client-sts": "^3.700.0",
    "@azure/msal-node": "^3.0.0",
    "axios": "^1.7.0",
    "chart.js": "^4.4.0",
    "cmdk": "^1.0.0",
    "electron-updater": "^6.3.0",
    "googleapis": "^144.0.0",
    "i18next": "^24.0.0",
    "react": "^18.3.1",
    "react-chartjs-2": "^5.2.0",
    "react-dom": "^18.3.1",
    "react-i18next": "^15.0.0",
    "tesseract.js": "^5.1.0",
    "webdav": "^5.3.0",
    "zustand": "^5.0.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.48.0",
    "@testing-library/react": "^16.3.2",
    "@types/bun": "^1.3.11",
    "@types/node": "^22.0.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.0",
    "electron": "^32.0.0",
    "electron-builder": "^25.0.0",
    "electron-vite": "^3.0.0",
    "jsdom": "^29.0.1",
    "playwright": "^1.48.0",
    "typescript": "^5.6.0",
    "vite": "^6.0.0",
    "vitest": "^2.1.0"
  }
}
